#!/usr/bin/env bash
# SessionStart hook for cadence plugin
#
# Emits a one-line activation marker. Full routing rules live in the
# cadence:using-cadence skill body — the model loads them when the
# UserPromptSubmit hook nudges it to invoke the skill on the first turn.

set -euo pipefail

context="<IMPORTANT>Cadence is active. Invoke the \`cadence:using-cadence\` skill on the first turn to load routing rules.</IMPORTANT>"

if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{"additional_context": "%s"}\n' "$context"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
  printf '{"hookSpecificOutput": {"hookEventName": "SessionStart", "additionalContext": "%s"}}\n' "$context"
else
  printf '{"additionalContext": "%s"}\n' "$context"
fi

exit 0
