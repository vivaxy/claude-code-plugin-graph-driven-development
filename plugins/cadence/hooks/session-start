#!/usr/bin/env bash
# SessionStart hook for cadence plugin
#
# Reads the routing rules from skills/using-cadence/SKILL.md and emits them
# as session context so the model follows Cadence without a skill invocation.

set -euo pipefail

PLUGIN_ROOT="${CLAUDE_PLUGIN_ROOT:-${CURSOR_PLUGIN_ROOT:-}}"
SKILL_FILE="${PLUGIN_ROOT}/skills/using-cadence/SKILL.md"

if [ -f "$SKILL_FILE" ]; then
  # Substitute the shell variable placeholder with the actual resolved path so
  # agents see a literal path in their instructions — CLAUDE_PLUGIN_ROOT and
  # CURSOR_PLUGIN_ROOT are not set in the agent's Bash tool environment.
  skill_content="$(sed "s|\${CLAUDE_PLUGIN_ROOT:-\$CURSOR_PLUGIN_ROOT}|${PLUGIN_ROOT}|g" "$SKILL_FILE")"
else
  skill_content="Cadence is active. Session routing rules unavailable (SKILL.md not found at: ${SKILL_FILE})."
fi

raw_context="<IMPORTANT>Cadence is active. Routing rules follow.

cadence_plugin_root: ${PLUGIN_ROOT}

${skill_content}</IMPORTANT>"

# Use Python for safe JSON serialization — raw SKILL.md content contains
# newlines, quotes, and backslashes that break naive printf-based encoding.
if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  python3 -c "
import json, sys
context = sys.stdin.read()
print(json.dumps({'additional_context': context}))
" <<< "$raw_context"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
  python3 -c "
import json, sys
context = sys.stdin.read()
print(json.dumps({'hookSpecificOutput': {'hookEventName': 'SessionStart', 'additionalContext': context}}))
" <<< "$raw_context"
else
  python3 -c "
import json, sys
context = sys.stdin.read()
print(json.dumps({'additionalContext': context}))
" <<< "$raw_context"
fi

exit 0
