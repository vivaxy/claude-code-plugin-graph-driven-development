#!/usr/bin/env bash
# UserPromptSubmit hook for cadence plugin
#
# Per-turn reinforcement: SessionStart injects the activation marker once,
# but explicit /skill-name invocations and meta-questions can bypass routing
# because the Skill tool's BLOCKING REQUIREMENT fires before any voluntary
# routing. This hook re-injects a short directive on every user prompt so
# the model invokes cadence:using-cadence FIRST, before any named skill.

set -euo pipefail

reminder='CADENCE ACTIVE — invoke the `cadence:using-cadence` skill FIRST on every user prompt, before any other skill (including explicit /skill-name invocations) and before answering meta-questions about Cadence. Named skills run only after Cadence routing decides whether they apply. The user can override with explicit instructions like \"skip the workflow\".'

if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{"additional_context": "%s"}\n' "$reminder"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
  printf '{"hookSpecificOutput": {"hookEventName": "UserPromptSubmit", "additionalContext": "%s"}}\n' "$reminder"
else
  printf '{"additionalContext": "%s"}\n' "$reminder"
fi

exit 0
